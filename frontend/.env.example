# Frontend Environment Configuration - Vite
# Copy this file to .env and fill in with your actual values

# API Configuration
# For development with Docker: http://backend:8000/api/v1
# For local development: http://localhost:8000/api/v1
VITE_API_URL=http://localhost:8000/api/v1
VITE_BACKEND_URL=http://localhost:8000

# Application Info
VITE_APP_NAME=InboxAI
VITE_APP_VERSION=2.0.0

# OAuth Configuration
VITE_OAUTH_REDIRECT_URI=http://localhost:3000/oauth/callback
VITE_GOOGLE_CLIENT_ID=your_google_client_id_here
VITE_PAYSTACK_PUBLIC_KEY=pk_test_your_paystack_public_key_here

# Legacy REACT_APP_ keys are deprecated in this Vite app and are not required.


# Analytics & Tracking
VITE_ENABLE_ANALYTICS=false
VITE_SENTRY_DSN=your_sentry_dsn_here

# Development
VITE_DEBUG=false
VITE_LOG_LEVEL=error
