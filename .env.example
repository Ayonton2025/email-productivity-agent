# ============================================================================
# Email Productivity Agent - Environment Variables Template
# ============================================================================
# This is an example environment file. Copy this to .env and fill in values.
# NEVER commit .env file - use .env.example as a template
# ============================================================================

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================
DB_HOST=postgres
DB_PORT=5432
DB_USER=email_agent
DB_PASSWORD=change_this_strong_password
DB_NAME=email_agent_db

# PostgreSQL connection string (auto-constructed if DB_* vars are set)
DATABASE_URL=postgresql+asyncpg://email_agent:change_this_strong_password@postgres:5432/email_agent_db

# ============================================================================
# REDIS CONFIGURATION
# ============================================================================
REDIS_HOST=redis
REDIS_PORT=6379
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# ============================================================================
# GMAIL/GOOGLE OAUTH CONFIGURATION
# ============================================================================
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/oauth/callback/gmail

# Google Cloud Project for Pub/Sub notifications (optional)
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_CREDENTIALS_JSON=

# ============================================================================
# OUTLOOK/MICROSOFT OAUTH CONFIGURATION
# ============================================================================
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_REDIRECT_URI=http://localhost:3000/oauth/callback/outlook
MICROSOFT_TENANT=common

# ============================================================================
# YAHOO OAUTH CONFIGURATION
# ============================================================================
YAHOO_CLIENT_ID=
YAHOO_CLIENT_SECRET=
YAHOO_REDIRECT_URI=http://localhost:3000/oauth/callback/yahoo

# ============================================================================
# LLM / AI CONFIGURATION
# ============================================================================
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4

# Alternative: Use local/self-hosted LLM
# LLM_PROVIDER=ollama  # or openai, anthropic
# LLM_API_URL=http://localhost:11434
# LLM_MODEL=qwen2.5-7b-instruct-q4_k_m-00001-of-00002

# ============================================================================
# PAYMENT PROCESSING
# ============================================================================
PAYSTACK_API_KEY=
PAYSTACK_SECRET_KEY=sk_test_your_paystack_secret_key
PAYSTACK_PUBLIC_KEY=pk_test_your_paystack_public_key
PAYSTACK_API_BASE_URL=https://api.paystack.co
PAYSTACK_SUPPORTED_CURRENCIES=USD,KES,NGN
PAYSTACK_FALLBACK_CURRENCY=USD
PAYSTACK_FORCE_CURRENCY=
BILLING_CHARGE_CURRENCY=USD
BILLING_STRICT_USD=true
BILLING_FX_BUFFER_PERCENT=0
ENABLE_LIVE_FX_RATES=true
FX_RATE_API_BASE_URL=https://api.exchangerate.host
FX_RATE_CACHE_MINUTES=15
ENABLE_GEOIP_DETECTION=true
GEOIP_API_BASE_URL=https://ipapi.co

# PayPal (optional backup payment method)
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_MODE=sandbox
PAYPAL_API_BASE_URL=https://api-m.sandbox.paypal.com
PAYPAL_API_BASE_URL_LIVE=https://api-m.paypal.com

BYBIT_PAY_API_KEY=
BYBIT_PAY_API_SECRET=
BYBIT_PAY_MERCHANT_ID=
BYBIT_PAY_API_BASE=https://api.bybit.com

STRIPE_API_KEY=
STRIPE_SECRET_KEY=

# ============================================================================
# ELASTICSEARCH CONFIGURATION
# ============================================================================
ELASTICSEARCH_HOST=elasticsearch
ELASTICSEARCH_PORT=9200
ELASTICSEARCH_ENABLED=true

# ============================================================================
# APPLICATION CONFIGURATION
# ============================================================================
ENVIRONMENT=development
DEBUG=true
SECRET_KEY=your-secret-key-change-in-production
ENCRYPTION_KEY=28987c2d81b147ed08133a7e60fc453bcb82624c3b78b93a25ae5d8a435d3e2e

# Frontend URL for CORS
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000

# Webhook configuration for push notifications
WEBHOOK_BASE_URL=http://localhost:8000

# ============================================================================
# AUTHENTICATION
# ============================================================================
JWT_SECRET_KEY=your-jwt-secret-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ============================================================================
# INITIAL ADMIN USER (for DB initialization)
# ============================================================================
DEFAULT_ADMIN_EMAIL=admin@inboxai.com
DEFAULT_ADMIN_PASSWORD=change_this_password

# ============================================================================
# DATABASE INITIALIZATION
# ============================================================================
SKIP_DB_INIT=false
INIT_DB_MAX_RETRIES=60

# ============================================================================
# LOGGING
# ============================================================================
LOG_LEVEL=INFO
LOG_FORMAT=json

# ============================================================================
# FEATURE FLAGS
# ============================================================================
FEATURE_PUSH_NOTIFICATIONS=true
FEATURE_EMAIL_SCHEDULING=true
FEATURE_BULK_OPERATIONS=true
FEATURE_SEARCH=true

# ============================================================================
# RATE LIMITING
# ============================================================================
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_PERIOD=3600

# ============================================================================
# SECURITY
# ============================================================================
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000
CSRF_PROTECTION=true
CORS_ALLOW_CREDENTIALS=true

# ============================================================================
# OPTIONAL: ANALYTICS & MONITORING
# ============================================================================
SENTRY_DSN=
DATADOG_API_KEY=
NEWRELIC_LICENSE_KEY=

# ============================================================================
# OPTIONAL: EMAIL DISPATCH (for notifications)
# ============================================================================
SMTP_SERVER=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@inboxai.com

# ============================
# LLM Configuration
# ============================
# Local llama.cpp server (OpenAI-compatible)
LLM_PROVIDER=llama_cpp
LLM_MODEL=qwen2.5-7b-instruct-q4_k_m-00001-of-00002
# For local backend process:
LLAMA_CPP_BASE_URL=http://127.0.0.1:8000/v1
# For Docker backend container, use:
# LLAMA_CPP_BASE_URL=http://host.docker.internal:8000/v1
LLAMA_CPP_API_KEY=not-needed

# Legacy providers (optional, kept for backwards compatibility)
GOOGLE_API_KEY=your_google_api_key
OPENAI_API_KEY=your_openai_api_key
ANTHROPIC_API_KEY=your_anthropic_api_key

# ============================
# Email Provider Configuration
# ============================
# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/google/callback

# Outlook/Microsoft
OUTLOOK_CLIENT_ID=your_outlook_client_id
OUTLOOK_CLIENT_SECRET=your_outlook_client_secret
OUTLOOK_TENANT_ID=your_outlook_tenant_id

# SMTP for Campaign Sending
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_TLS=true

# ============================
# Payment Gateway Configuration
# ============================
# Paystack (for NGN payments)
PAYSTACK_API_KEY=pk_live_your_paystack_api_key
PAYSTACK_SECRET_KEY=sk_live_your_paystack_secret_key
PAYSTACK_PUBLIC_KEY=pk_live_your_paystack_public_key

# Stripe (alternative)
STRIPE_API_KEY=sk_live_your-stripe-api-key
STRIPE_WEBHOOK_SECRET=whsec_your-stripe-webhook-secret

# ============================
# Task Queue Configuration (Celery)
# ============================
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1
CELERY_TIMEZONE=UTC
CELERY_ENABLED=true

# ============================
# Frontend Configuration
# ============================
FRONTEND_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:5173

# ============================
# Server Configuration
# ============================
PORT=8000
HOST=0.0.0.0

# ============================
# Email Sync Configuration
# ============================
ENABLE_IMAP_IDLE=true
EMAIL_SYNC_INTERVAL=300
MAX_IMAP_CONNECTIONS_PER_USER=1

# ============================
# Feature Flags
# ============================
ENABLE_EMAIL_SYNC=true
ENABLE_AI_PROCESSING=true
ENABLE_MOCK_MODE=false
ENABLE_ANALYTICS=true
ANALYTICS_RETENTION_DAYS=90
ADMIN_EMAILS=

# ============================
# Security Configuration
# ============================
BCRYPT_ROUNDS=12
JWT_ALGORITHM=HS256

# ============================
# Logging Configuration
# ============================
LOG_LEVEL=INFO
LOG_FILE=logs/app.log
